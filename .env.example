# === Telegram API credentials (get from https://my.telegram.org/apps) ===
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Your Telegram phone number (international format)
PHONE_NUMBER=+201234567890

# Groups to monitor — username or numeric ID (comma-separated, no spaces)
SOURCE_GROUPS=group1,group2,group3

# Your Telegram username or numeric user ID — proposals are sent here
ADMIN_USERNAME=your_username

# === AI provider (pick one, detected automatically by key prefix) ===
# Gemini: key starts with "AIza" — free tier, 1500 req/day
#   AI_MODEL=gemini-2.5-flash        (free, good Arabic)
#
# OpenAI: key starts with "sk-" — $0.15/M tokens (gpt-4o-mini)
#   AI_MODEL=gpt-4o-mini
#   AI_API_URL=https://api.openai.com/v1/chat/completions   (optional, default for sk- keys)
#
# DeepSeek: key starts with "sk-" too, set custom URL
#   AI_MODEL=deepseek-chat
#   AI_API_URL=https://api.deepseek.com/v1/chat/completions
#
# Groq / OpenRouter / any OpenAI-compatible API — set custom URL
#   AI_API_URL=https://api.groq.com/openai/v1/chat/completions

# `API_KEY` (primary, tried first):
GEMINI_API_KEY=
OPENAI_API_KEY=

# Fallback providers (each tried in order if primary fails):
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_URL=https://api.groq.com/openai/v1/chat/completions
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwq-32b
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama3.1-8b
CEREBRAS_URL=https://api.cerebras.ai/v1/chat/completions

# Model override for primary key (Gemini or OpenAI):
AI_MODEL=gpt-4o-mini
AI_API_URL=

# === Optional: proxy (needed if Telegram is blocked in your region) ===
# PROXY_IP=127.0.0.1
# PROXY_PORT=1080
# PROXY_TYPE=socks5   # socks5, socks4, or mtproto
# PROXY_SECRET=       # only needed for mtproto

# === Optional: Bot API for real notifications ===
# Create a bot at @BotFather, add it as admin in your target group
BOT_TOKEN=
BOT_CHAT_ID=

# Optional: session string (filled automatically after first run, reuse to avoid OTP)
SESSION_STRING=
