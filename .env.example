# Get these from https://my.telegram.org/apps
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Your Telegram phone number (international format)
PHONE_NUMBER=+201234567890

# The groups to monitor — use group username or numeric ID (comma-separated, no spaces)
# Username example:  mygroup1,mygroup2,mygroup3
# Numeric ID example: -1001234567890,-1009876543210,-1001122334455
SOURCE_GROUPS=group1_username,group2_username,group3_username

# Your own Telegram username or numeric user ID — messages will be sent here
ADMIN_USERNAME=your_username

# NVIDIA API key for AI proposal generation (get from https://build.nvidia.com)
NVIDIA_API_KEY=
NVIDIA_MODEL=

# Optional: proxy (needed if Telegram is blocked in your region)
# PROXY_IP=127.0.0.1
# PROXY_PORT=1080
# PROXY_TYPE=socks5   # socks5, socks4, or mtproto
# PROXY_SECRET=       # only needed for mtproto

# Optional: Bot token for sending notifications via Bot API (fixes "no notification" issue)
# Messages come from the bot, not your account, so you get real notifications
# Create bot at https://t.me/BotFather and add it admin to your target group
BOT_TOKEN=
BOT_CHAT_ID=

# Optional: session string to avoid re-login (filled automatically after first run)
SESSION_STRING=
